  "questions": [
    {
      "id": 1,
      "type": "text_choice",
      "locale_data": {
        "en": { "text": "A friend says something\nthat lowkey offends you. You..." },
        "ko": { "text": "친구가 은근히\n기분 나쁜 말을 한다. 나는?" }
      },
      "options": [
        {
          "locale_data": {
            "en": { "text": "Call it out right away" },
            "ko": { "text": "바로 지적한다" }
          },
          "emoji": "🗣️",
          "scores": { "fight": 3 }
        },
        {
          "locale_data": {
            "en": { "text": "Let it slide and move on" },
            "ko": { "text": "그냥 넘어간다" }
          },
          "emoji": "😶",
          "scores": { "flight": 3 }
        },
        {
          "locale_data": {
            "en": { "text": "Bring it up later in private" },
            "ko": { "text": "나중에 따로 얘기한다" }
          },
          "emoji": "💬",
          "scores": { "fix": 3 }
        },
        {
          "locale_data": {
            "en": { "text": "Feel hurt but say nothing" },
            "ko": { "text": "상처받지만 말 못 한다" }
          },
          "emoji": "💔",
          "scores": { "feel": 3 }
        }
      ]
    },
    {
      "id": 2,
      "type": "image_grid",
      "locale_data": {
        "en": { "text": "In the middle of a heated argument,\nyou're most likely to..." },
        "ko": { "text": "격한 논쟁 중에\n나는 보통..." }
      },
      "options": [
        {
          "locale_data": {
            "en": { "text": "Raise my voice" },
            "ko": { "text": "목소리가 커짐" }
          },
          "emoji": "📢",
          "scores": { "fight": 3 }
        },
        {
          "locale_data": {
            "en": { "text": "Walk away" },
            "ko": { "text": "자리를 뜸" }
          },
          "emoji": "🚶",
          "scores": { "flight": 3 }
        },
        {
          "locale_data": {
            "en": { "text": "Find middle ground" },
            "ko": { "text": "타협점 탐색" }
          },
          "emoji": "🤝",
          "scores": { "fix": 3 }
        },
        {
          "locale_data": {
            "en": { "text": "Start crying" },
            "ko": { "text": "눈물이 남" }
          },
          "emoji": "😢",
          "scores": { "feel": 3 }
        }
      ]
    },
    {
      "id": 3,
      "type": "binary",
      "locale_data": {
        "en": { "text": "After a big fight,\nwho reaches out first?" },
        "ko": { "text": "큰 싸움 후에\n먼저 연락하는 쪽은?" }
      },
      "options": [
        {
          "locale_data": {
            "en": { "text": "I do — can't leave it unresolved" },
            "ko": { "text": "내가 — 미해결이 싫어서" }
          },
          "emoji": "📱",
          "scores": { "fix": 2, "feel": 1 }
        },
        {
          "locale_data": {
            "en": { "text": "I wait for them" },
            "ko": { "text": "상대가 먼저 하길 기다림" }
          },
          "emoji": "⏳",
          "scores": { "flight": 2, "fight": 1 }
        }
      ]
    },
    {
      "id": 4,
      "type": "text_choice",
      "locale_data": {
        "en": { "text": "Someone cuts in line\nright in front of you" },
        "ko": { "text": "누군가 내 앞에서\n새치기를 한다" }
      },
      "options": [
        {
          "locale_data": {
            "en": { "text": "Excuse me, the line's back there" },
            "ko": { "text": "저기요 줄은 뒤에요" }
          },
          "emoji": "✋",
          "scores": { "fight": 2, "fix": 1 }
        },
        {
          "locale_data": {
            "en": { "text": "Annoyed but I let it go" },
            "ko": { "text": "짜증나지만 참는다" }
          },
          "emoji": "😤",
          "scores": { "flight": 2, "feel": 1 }
        },
        {
          "locale_data": {
            "en": { "text": "Politely point it out" },
            "ko": { "text": "부드럽게 알려준다" }
          },
          "emoji": "🙂",
          "scores": { "fix": 3 }
        },
        {
          "locale_data": {
            "en": { "text": "Stew in silence and rant later" },
            "ko": { "text": "속으로 삭이고 나중에 하소연" }
          },
          "emoji": "🫨",
          "scores": { "feel": 2, "flight": 1 }
        }
      ]
    },
    {
      "id": 5,
      "type": "image_grid",
      "locale_data": {
        "en": { "text": "Your partner forgot\nsomething important to you" },
        "ko": { "text": "연인이 중요한 걸\n깜빡했다. 나는?" }
      },
      "options": [
        {
          "locale_data": {
            "en": { "text": "Confront directly" },
            "ko": { "text": "바로 따진다" }
          },
          "emoji": "😠",
          "scores": { "fight": 3 }
        },
        {
          "locale_data": {
            "en": { "text": "Say it's fine" },
            "ko": { "text": "괜찮다고 함" }
          },
          "emoji": "🙂",
          "scores": { "flight": 2, "feel": 1 }
        },
        {
          "locale_data": {
            "en": { "text": "Explain how I feel" },
            "ko": { "text": "내 감정을 설명" }
          },
          "emoji": "💭",
          "scores": { "fix": 2, "feel": 1 }
        },
        {
          "locale_data": {
            "en": { "text": "Get quietly upset" },
            "ko": { "text": "조용히 서운해함" }
          },
          "emoji": "🥺",
          "scores": { "feel": 3 }
        }
      ]
    },
    {
      "id": 6,
      "type": "binary",
      "locale_data": {
        "en": { "text": "In group conflicts,\nyou tend to..." },
        "ko": { "text": "단체 갈등 상황에서\n나는 보통?" }
      },
      "options": [
        {
          "locale_data": {
            "en": { "text": "Pick a side and defend it" },
            "ko": { "text": "편 들고 방어한다" }
          },
          "emoji": "⚔️",
          "scores": { "fight": 2, "fix": 1 }
        },
        {
          "locale_data": {
            "en": { "text": "Stay neutral no matter what" },
            "ko": { "text": "무조건 중립 유지" }
          },
          "emoji": "🧘",
          "scores": { "flight": 1, "fix": 2 }
        }
      ]
    },
    {
      "id": 7,
      "type": "text_choice",
      "locale_data": {
        "en": { "text": "A week after a fight,\nyou're still thinking about it because..." },
        "ko": { "text": "싸운 지 일주일 후에도\n생각나는 이유는?" }
      },
      "options": [
        {
          "locale_data": {
            "en": { "text": "I should've said more" },
            "ko": { "text": "더 할 말이 있었는데 못해서" }
          },
          "emoji": "😤",
          "scores": { "fight": 3 }
        },
        {
          "locale_data": {
            "en": { "text": "I wish I hadn't engaged at all" },
            "ko": { "text": "아예 안 싸웠으면 좋았는데" }
          },
          "emoji": "😔",
          "scores": { "flight": 3 }
        },
        {
          "locale_data": {
            "en": { "text": "I keep refining what I should say next" },
            "ko": { "text": "다음엔 뭐라고 할지 정리 중" }
          },
          "emoji": "📝",
          "scores": { "fix": 3 }
        },
        {
          "locale_data": {
            "en": { "text": "The emotions just won't go away" },
            "ko": { "text": "감정이 계속 남아있어서" }
          },
          "emoji": "🫠",
          "scores": { "feel": 3 }
        }
      ]
    }
