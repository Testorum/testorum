  "results": [
    {
      "id": "fight",
      "locale_data": {
        "en": {
          "title": "The Direct Confronter",
          "description": "You face problems head-on — no sugarcoating, no dodging. People know where they stand with you, which is refreshing. Just watch the delivery — sometimes the message gets lost in the heat.",
